# --- Flask / core (copy to .env for local) ---
SECRET_KEY=change-me-in-production
FLASK_APP=app.py
FLASK_ENV=development
# Production on AWS:
# FLASK_ENV=production
# SECRET_KEY=<strong-random-string>

# --- Database (local SQLite = leave DATABASE_URL unset) ---
# For PostgreSQL (Docker or Amazon RDS) use the psycopg2 driver in the URL:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/whiteboard

# --- Local file uploads (ignored when USE_S3=true) ---
UPLOAD_FOLDER=./uploads

# --- AWS (region used by S3, optional CloudWatch metrics) ---
AWS_REGION=us-east-1
# On EC2/Elastic Beanstalk, prefer IAM instance role over static keys. Optional:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- S3 materials (set on EB for production files) ---
USE_S3=false
S3_BUCKET_NAME=
S3_MATERIALS_PREFIX=materials/
# Presigned URL lifetime in seconds (view/download)
S3_PRESIGN_EXPIRES=3600

# --- CloudWatch ---
# Gunicorn logs already go to stdout (EB -> CloudWatch Logs by default). When true, also
# sends PutMetricData for each activity in log_activity (ActivityAction, dimension Action=...).
ENABLE_CLOUDWATCH=false
CLOUDWATCH_LOG_GROUP=/whiteboard/app
CLOUDWATCH_METRIC_NAMESPACE=Whiteboard/App

# --- Production HTTPS (set in Elastic Beanstalk software environment) ---
# PREFERRED_URL_SCHEME=https
# SESSION_COOKIE_SECURE=true
